// ================================================================
// ISC PRO ANALYZER v1.0
// Professional Smart Money Analysis
// For: XAUUSD Spot | XAUUSD Futures | Forex Pairs
// Style: Clean · Transparent · Limit Entry
// Concepts: FVG · IRL/ERL · OB · Key Level · Fibonacci · BOS
// ================================================================

//@version=5
indicator("ISC Pro Analyzer", shorttitle="ISC Pro", overlay=true,
     max_boxes_count  = 500,
     max_lines_count  = 500,
     max_labels_count = 500)

// ================================================================
// ░░  SETTINGS
// ================================================================

g_kl  = "🔑 Key Levels"
g_fvg = "📐 FVG — Fair Value Gap"
g_liq = "💧 Liquidity"
g_ob  = "📦 Order Block"
g_ses = "⏰ Sessions"
g_en  = "🎯 Entry & Trade"
g_col = "🎨 Colors"

// Key Level
show_kl     = input.bool(true,  "Show Key Levels",         group=g_kl)
kl_lookback = input.int(30,     "Key Level Lookback",      group=g_kl, minval=10, maxval=200)
kl_extend   = input.int(100,    "Extend Lines (bars)",     group=g_kl, minval=20, maxval=500)

// FVG
show_fvg    = input.bool(true,  "Show FVG Zones",          group=g_fvg)
fvg_min     = input.float(0.0,  "Min FVG Size (ATR mult)", group=g_fvg, minval=0.0, step=0.1)
fvg_extend  = input.int(60,     "FVG Extend (bars)",       group=g_fvg, minval=10, maxval=300)

// Liquidity
show_erl    = input.bool(true,  "Show External Liquidity (ERL)", group=g_liq)
show_irl    = input.bool(true,  "Show Internal Liquidity (IRL)", group=g_liq)
show_sweep  = input.bool(true,  "Show Sweep Labels",             group=g_liq)
liq_len     = input.int(10,     "Liquidity Swing Length",        group=g_liq, minval=3, maxval=50)

// Order Block
show_ob     = input.bool(true,  "Show Order Blocks",       group=g_ob)
ob_len      = input.int(3,      "OB Lookback Bars",        group=g_ob, minval=1, maxval=10)
ob_extend   = input.int(50,     "OB Extend (bars)",        group=g_ob, minval=10, maxval=200)

// Sessions
show_bg     = input.bool(true,  "Session Background",      group=g_ses)
show_ahl    = input.bool(true,  "Asia High/Low",           group=g_ses)
asia_s      = input.int(1,  "Asia Start UTC",   group=g_ses, minval=0, maxval=23)
asia_e      = input.int(5,  "Asia End UTC",     group=g_ses, minval=0, maxval=23)
lon_s       = input.int(7,  "London Start UTC", group=g_ses, minval=0, maxval=23)
lon_e       = input.int(10, "London End UTC",   group=g_ses, minval=0, maxval=23)
ny_s        = input.int(12, "NY Start UTC",     group=g_ses, minval=0, maxval=23)
ny_e        = input.int(15, "NY End UTC",       group=g_ses, minval=0, maxval=23)

// Entry
show_limit  = input.bool(true,  "Show Limit Entry Line",   group=g_en)
sl_mult     = input.float(0.8,  "SL ATR Multiplier",       group=g_en, minval=0.1, step=0.1)
rr_val      = input.float(3.0,  "Risk:Reward Target",      group=g_en, minval=1.0, step=0.5)
atr_len     = input.int(14,     "ATR Length",              group=g_en)

// Colors
c_bear_kl   = input.color(color.new(#FF6B6B, 15), "Resistance / Bearish", group=g_col)
c_bull_kl   = input.color(color.new(#00D4AA, 15), "Support / Bullish",    group=g_col)
c_fvg_bear  = input.color(color.new(#FF6B6B, 82), "FVG Bearish",          group=g_col)
c_fvg_bull  = input.color(color.new(#00D4AA, 82), "FVG Bullish",          group=g_col)
c_ob_bear   = input.color(color.new(#FF6B6B, 72), "OB Bearish",           group=g_col)
c_ob_bull   = input.color(color.new(#00D4AA, 72), "OB Bullish",           group=g_col)
c_erl       = input.color(color.new(#FFD700, 0),  "ERL (External Liq)",   group=g_col)
c_irl       = input.color(color.new(#A29BFE, 0),  "IRL (Internal Liq)",   group=g_col)
c_asia      = input.color(color.new(#7B7BFF, 91), "Asia BG",              group=g_col)
c_lon       = input.color(color.new(#FFD700, 91), "London BG",            group=g_col)
c_ny        = input.color(color.new(#00D4AA, 91), "NY BG",                group=g_col)
c_sl        = input.color(color.new(#FF4757, 0),  "Stop Loss",            group=g_col)
c_tp        = input.color(color.new(#2ED573, 0),  "Take Profit",          group=g_col)
c_entry     = input.color(color.new(#FFD700, 0),  "Limit Entry",          group=g_col)

// ================================================================
// ░░  BASE CALC
// ================================================================

atr   = ta.atr(atr_len)
barH  = hour(time, "UTC")

inS(a, b) => barH >= a and barH < b

in_asia = inS(asia_s, asia_e)
in_lon  = inS(lon_s,  lon_e)
in_ny   = inS(ny_s,   ny_e)
in_kz   = in_lon or in_ny

// ================================================================
// ░░  SESSION BACKGROUNDS
// ================================================================

bgcolor(show_bg and in_asia ? c_asia : na, title="Asia")
bgcolor(show_bg and in_lon  ? c_lon  : na, title="London")
bgcolor(show_bg and in_ny   ? c_ny   : na, title="NY")

// ================================================================
// ░░  ASIA HIGH / LOW
// ================================================================

var float ah = na
var float al = na
var int   ab = na
var bool  a_active = false

if in_asia and not in_asia[1]
    ah       := high
    al       := low
    ab       := bar_index
    a_active := false

if in_asia
    ah := math.max(ah, high)
    al := math.min(al, low)

var line ahl_h = na
var line ahl_l = na

if show_ahl and not in_asia and in_asia[1]
    line.delete(ahl_h)
    line.delete(ahl_l)
    ahl_h := line.new(ab, ah, bar_index + 120, ah,
         color=color.new(#FFD700, 35), style=line.style_dashed, width=1)
    ahl_l := line.new(ab, al, bar_index + 120, al,
         color=color.new(#7B7BFF, 35), style=line.style_dashed, width=1)
    label.new(bar_index, ah, "Asia High",
         color=color.new(#FFD700, 75), textcolor=#FFD700,
         style=label.style_label_left, size=size.tiny)
    label.new(bar_index, al, "Asia Low",
         color=color.new(#7B7BFF, 75), textcolor=#7B7BFF,
         style=label.style_label_left, size=size.tiny)
    a_active := true

if show_ahl and a_active and not na(ahl_h)
    line.set_x2(ahl_h, bar_index)
    line.set_x2(ahl_l, bar_index)

// ================================================================
// ░░  KEY LEVELS — clean horizontal lines with zone boxes
// ================================================================

ph_kl = ta.pivothigh(high, kl_lookback, kl_lookback)
pl_kl = ta.pivotlow(low,   kl_lookback, kl_lookback)

// Resistance Key Level
if show_kl and not na(ph_kl)
    kl_bar = bar_index - kl_lookback

    // Main key level line
    line.new(kl_bar, ph_kl, kl_bar + kl_extend, ph_kl,
         color=color.new(c_bear_kl, 20), style=line.style_solid, width=2)

    // Thin zone box (premium zone)
    box.new(kl_bar, ph_kl + atr * 0.08, kl_bar + kl_extend, ph_kl - atr * 0.02,
         bgcolor=c_bear_kl, border_color=na)

    // Key level label
    label.new(kl_bar, ph_kl + atr * 0.12,
         "KEY  " + str.tostring(ph_kl, format.mintick),
         color=color.new(#FF6B6B, 65), textcolor=#FF6B6B,
         style=label.style_label_right, size=size.tiny)

// Support Key Level
if show_kl and not na(pl_kl)
    kl_bar = bar_index - kl_lookback

    line.new(kl_bar, pl_kl, kl_bar + kl_extend, pl_kl,
         color=color.new(c_bull_kl, 20), style=line.style_solid, width=2)

    box.new(kl_bar, pl_kl + atr * 0.02, kl_bar + kl_extend, pl_kl - atr * 0.08,
         bgcolor=c_bull_kl, border_color=na)

    label.new(kl_bar, pl_kl - atr * 0.12,
         "KEY  " + str.tostring(pl_kl, format.mintick),
         color=color.new(#00D4AA, 65), textcolor=#00D4AA,
         style=label.style_label_right, size=size.tiny)

// ================================================================
// ░░  FVG — Fair Value Gap (Imbalance)
// ================================================================

// Bearish FVG: high[2] < low[0] → gap between candle 3 and candle 1
bearFVG = show_fvg and high[2] < low and (low - high[2]) > atr * fvg_min

// Bullish FVG: low[2] > high[0] → gap between candle 3 and candle 1
bullFVG = show_fvg and low[2] > high and (low[2] - high) > atr * fvg_min

if bearFVG
    fvg_top    = low
    fvg_bottom = high[2]
    fvg_mid    = (fvg_top + fvg_bottom) / 2
    fvg_bar    = bar_index - 1

    box.new(fvg_bar, fvg_top, fvg_bar + fvg_extend, fvg_bottom,
         bgcolor=c_fvg_bear, border_color=color.new(#FF6B6B, 60), border_width=1)

    // Mid line (equilibrium)
    line.new(fvg_bar, fvg_mid, fvg_bar + fvg_extend, fvg_mid,
         color=color.new(#FF6B6B, 50), style=line.style_dotted, width=1)

    label.new(fvg_bar, fvg_top, "FVG",
         color=color.new(#FF6B6B, 70), textcolor=#FF6B6B,
         style=label.style_label_down, size=size.tiny)

if bullFVG
    fvg_top    = low[2]
    fvg_bottom = high
    fvg_mid    = (fvg_top + fvg_bottom) / 2
    fvg_bar    = bar_index - 1

    box.new(fvg_bar, fvg_top, fvg_bar + fvg_extend, fvg_bottom,
         bgcolor=c_fvg_bull, border_color=color.new(#00D4AA, 60), border_width=1)

    line.new(fvg_bar, fvg_mid, fvg_bar + fvg_extend, fvg_mid,
         color=color.new(#00D4AA, 50), style=line.style_dotted, width=1)

    label.new(fvg_bar, fvg_bottom, "FVG",
         color=color.new(#00D4AA, 70), textcolor=#00D4AA,
         style=label.style_label_up, size=size.tiny)

// ================================================================
// ░░  LIQUIDITY — External (ERL) & Internal (IRL)
// ================================================================

// Swing points for liquidity
swing_h = ta.pivothigh(high, liq_len, liq_len)
swing_l  = ta.pivotlow(low,   liq_len, liq_len)

var float last_sh = na
var float last_sl = na
var int   sh_b    = na
var int   sl_b    = na

// Track last 2 swing highs and lows for ERL vs IRL
var float prev_sh = na
var float prev_sl = na

if not na(swing_h)
    prev_sh  := last_sh
    last_sh  := swing_h
    sh_b     := bar_index - liq_len

if not na(swing_l)
    prev_sl  := last_sl
    last_sl  := swing_l
    sl_b     := bar_index - liq_len

// ERL = most recent major swing high/low (buy side / sell side liquidity)
// IRL = internal swing (inducement level)

if show_erl and not na(swing_h)
    line.new(bar_index - liq_len, swing_h, bar_index + 30, swing_h,
         color=color.new(c_erl, 30), style=line.style_dotted, width=1)
    label.new(bar_index - liq_len, swing_h,
         "ERL · Buy Side Liq",
         color=color.new(c_erl, 75), textcolor=c_erl,
         style=label.style_label_right, size=size.tiny)

if show_erl and not na(swing_l)
    line.new(bar_index - liq_len, swing_l, bar_index + 30, swing_l,
         color=color.new(c_erl, 30), style=line.style_dotted, width=1)
    label.new(bar_index - liq_len, swing_l,
         "ERL · Sell Side Liq",
         color=color.new(c_erl, 75), textcolor=c_erl,
         style=label.style_label_right, size=size.tiny)

// IRL detection: small internal swing within a leg (shorter lookback)
irl_h = ta.pivothigh(high, math.round(liq_len / 2), math.round(liq_len / 2))
irl_l = ta.pivotlow(low,   math.round(liq_len / 2), math.round(liq_len / 2))

// Only show IRL if it's NOT the same as ERL
irl_is_diff_h = not na(irl_h) and not na(last_sh) and math.abs(irl_h - last_sh) > atr * 0.3
irl_is_diff_l = not na(irl_l) and not na(last_sl) and math.abs(irl_l - last_sl) > atr * 0.3

if show_irl and irl_is_diff_h
    line.new(bar_index - math.round(liq_len / 2), irl_h, bar_index + 20, irl_h,
         color=color.new(c_irl, 45), style=line.style_dotted, width=1)
    label.new(bar_index - math.round(liq_len / 2), irl_h, "IRL",
         color=color.new(c_irl, 75), textcolor=c_irl,
         style=label.style_label_right, size=size.tiny)

if show_irl and irl_is_diff_l
    line.new(bar_index - math.round(liq_len / 2), irl_l, bar_index + 20, irl_l,
         color=color.new(c_irl, 45), style=line.style_dotted, width=1)
    label.new(bar_index - math.round(liq_len / 2), irl_l, "IRL",
         color=color.new(c_irl, 75), textcolor=c_irl,
         style=label.style_label_right, size=size.tiny)

// ================================================================
// ░░  LIQUIDITY SWEEP DETECTION
// ================================================================

// Sweep = wick breaks swing, candle closes back
sweep_bull = show_sweep and not na(last_sl) and low < last_sl and close > last_sl
sweep_bear = show_sweep and not na(last_sh) and high > last_sh and close < last_sh

if sweep_bull
    label.new(bar_index, low - atr * 0.4, "LS+",
         color=color.new(#00D4AA, 55), textcolor=#00D4AA,
         style=label.style_label_up, size=size.small)

if sweep_bear
    label.new(bar_index, high + atr * 0.4, "LS-",
         color=color.new(#FF6B6B, 55), textcolor=#FF6B6B,
         style=label.style_label_down, size=size.small)

// ================================================================
// ░░  BOS — Break of Structure (silent, used for signal)
// ================================================================

bos_up = not na(last_sh) and close > last_sh and close[1] <= last_sh
bos_dn = not na(last_sl) and close < last_sl and close[1] >= last_sl

// Draw thin BOS line
if bos_up
    line.new(sh_b, last_sh, bar_index, last_sh,
         color=color.new(#00D4AA, 60), style=line.style_solid, width=1)
    label.new(bar_index, last_sh, "BOS",
         color=color.new(#00D4AA, 70), textcolor=#00D4AA,
         style=label.style_label_left, size=size.tiny)

if bos_dn
    line.new(sl_b, last_sl, bar_index, last_sl,
         color=color.new(#FF6B6B, 60), style=line.style_solid, width=1)
    label.new(bar_index, last_sl, "BOS",
         color=color.new(#FF6B6B, 70), textcolor=#FF6B6B,
         style=label.style_label_left, size=size.tiny)

// ================================================================
// ░░  ORDER BLOCK — with extend
// ================================================================

// Bearish OB: last bullish candle before bearish impulse
bearOB = show_ob and close[ob_len] > open[ob_len] and (open - close) > atr * 1.2 and close < open

// Bullish OB: last bearish candle before bullish impulse
bullOB = show_ob and close[ob_len] < open[ob_len] and (close - open) > atr * 1.2 and close > open

if bearOB
    ob_b   = bar_index - ob_len
    ob_top = high[ob_len]
    ob_bot = low[ob_len]
    ob_mid = (ob_top + ob_bot) / 2

    box.new(ob_b, ob_top, ob_b + ob_extend, ob_bot,
         bgcolor=c_ob_bear, border_color=color.new(#FF6B6B, 40), border_width=1)

    // Mid line
    line.new(ob_b, ob_mid, ob_b + ob_extend, ob_mid,
         color=color.new(#FF6B6B, 55), style=line.style_dotted, width=1)

    label.new(ob_b, ob_top, "OB",
         color=color.new(#FF6B6B, 65), textcolor=#FF6B6B,
         style=label.style_label_down, size=size.tiny)

if bullOB
    ob_b   = bar_index - ob_len
    ob_top = high[ob_len]
    ob_bot = low[ob_len]
    ob_mid = (ob_top + ob_bot) / 2

    box.new(ob_b, ob_top, ob_b + ob_extend, ob_bot,
         bgcolor=c_ob_bull, border_color=color.new(#00D4AA, 40), border_width=1)

    line.new(ob_b, ob_mid, ob_b + ob_extend, ob_mid,
         color=color.new(#00D4AA, 55), style=line.style_dotted, width=1)

    label.new(ob_b, ob_bot, "OB",
         color=color.new(#00D4AA, 65), textcolor=#00D4AA,
         style=label.style_label_up, size=size.tiny)

// ================================================================
// ░░  INDUCEMENT — internal
// ================================================================

ind_bull = close[2] > open[2] and high[1] < high[2] and low[1] > low[2] and close > open
ind_bear = close[2] < open[2] and low[1] > low[2]   and high[1] < high[2] and close < open

// ================================================================
// ░░  SNIPER ENTRY SIGNAL
//
//  BUY  = Kill Zone + Sweep Lows + BOS Up + (bullOB or ind_bull)
//  SELL = Kill Zone + Sweep Highs + BOS Dn + (bearOB or ind_bear)
// ================================================================

buy_sig  = in_kz and sweep_bull and bos_up and (bullOB or ind_bull)
sell_sig = in_kz and sweep_bear and bos_dn and (bearOB or ind_bear)

// ================================================================
// ░░  TRADE MANAGEMENT (locked on signal bar)
// ================================================================

var float t_ep  = na
var float t_sl  = na
var float t_tp  = na
var bool  t_on  = false
var bool  t_buy = false

var int   tot = 0
var int   won = 0
var int   lst = 0
var float rw  = 0.0
var float rl  = 0.0

if buy_sig and not t_on
    t_ep  := close
    t_sl  := low  - atr * sl_mult
    t_tp  := close + (close - t_sl) * rr_val
    t_on  := true
    t_buy := true
    tot   += 1

if sell_sig and not t_on
    t_ep  := close
    t_sl  := high + atr * sl_mult
    t_tp  := close - (t_sl - close) * rr_val
    t_on  := true
    t_buy := false
    tot   += 1

if t_on
    if t_buy
        if low <= t_sl
            t_on := false
            lst  += 1
            rl   += 1.0
        else if high >= t_tp
            t_on := false
            won  += 1
            rw   += rr_val
    else
        if high >= t_sl
            t_on := false
            lst  += 1
            rl   += 1.0
        else if low <= t_tp
            t_on := false
            won  += 1
            rw   += rr_val

// ================================================================
// ░░  DRAW LIMIT ENTRY — clean professional style
// ================================================================

var line l_ep  = na
var line l_sl  = na
var line l_tp  = na
var label lb_ep = na
var label lb_sl = na
var label lb_tp = na
var box   bx_tp = na
var box   bx_sl = na

if (buy_sig or sell_sig) and not t_on[1]
    line.delete(l_ep)
    line.delete(l_sl)
    line.delete(l_tp)
    label.delete(lb_ep)
    label.delete(lb_sl)
    label.delete(lb_tp)
    box.delete(bx_tp)
    box.delete(bx_sl)

    is_b  = buy_sig
    ep    = close
    sl    = is_b ? low  - atr * sl_mult         : high + atr * sl_mult
    tp    = is_b ? ep   + (ep - sl) * rr_val    : ep   - (sl - ep) * rr_val
    risk  = math.abs(ep - sl)
    cb    = bar_index
    ext   = cb + 80

    // ── Limit Entry line (gold dashed = pending limit order)
    l_ep  := line.new(cb, ep, ext, ep,
         color=c_entry, style=line.style_dashed, width=2)

    // ── SL line
    l_sl  := line.new(cb, sl, ext, sl,
         color=c_sl, style=line.style_solid, width=1)

    // ── TP line
    l_tp  := line.new(cb, tp, ext, tp,
         color=c_tp, style=line.style_solid, width=1)

    // ── TP zone (entry → TP) — shaded green
    bx_tp := box.new(cb, is_b ? tp : ep, ext, is_b ? ep : tp,
         bgcolor=color.new(#2ED573, 93), border_color=na)

    // ── SL zone (entry → SL) — shaded red
    bx_sl := box.new(cb, is_b ? ep : sl, ext, is_b ? sl : ep,
         bgcolor=color.new(#FF4757, 93), border_color=na)

    // ── Labels
    if show_limit
        lb_ep := label.new(ext + 1, ep,
             "LIMIT  " + str.tostring(ep, format.mintick),
             color=color.new(#FFD700, 75), textcolor=#FFD700,
             style=label.style_label_left, size=size.small)

        lb_sl := label.new(ext + 1, sl,
             "SL · " + str.tostring(sl, format.mintick) + "  (−1R)",
             color=color.new(#FF4757, 75), textcolor=#FF4757,
             style=label.style_label_left, size=size.small)

        lb_tp := label.new(ext + 1, tp,
             "TP · " + str.tostring(tp, format.mintick) + "  (+" + str.tostring(rr_val,"#.#") + "R)",
             color=color.new(#2ED573, 75), textcolor=#2ED573,
             style=label.style_label_left, size=size.small)

    // ── Signal arrow
    if is_b
        label.new(cb, low - atr * 1.8,
             "▲  BUY LIMIT",
             color=#00D4AA, textcolor=color.white,
             style=label.style_label_up, size=size.normal)
    else
        label.new(cb, high + atr * 1.8,
             "▼  SELL LIMIT",
             color=#FF6B6B, textcolor=color.white,
             style=label.style_label_down, size=size.normal)

// ================================================================
// ░░  ALERTS
// ================================================================

alertcondition(buy_sig,   "ISC · BUY LIMIT",   "🟡 ISC LIMIT BUY | {{ticker}} | {{interval}} | Entry: {{close}}")
alertcondition(sell_sig,  "ISC · SELL LIMIT",  "🟡 ISC LIMIT SELL | {{ticker}} | {{interval}} | Entry: {{close}}")
alertcondition(sweep_bull,"ISC · Sweep Lows",  "⚡ Sweep LOWS — watch BUY setup | {{ticker}}")
alertcondition(sweep_bear,"ISC · Sweep Highs", "⚡ Sweep HIGHS — watch SELL setup | {{ticker}}")
alertcondition(bos_up,    "ISC · BOS Up",      "📈 BOS Bullish | {{ticker}}")
alertcondition(bos_dn,    "ISC · BOS Down",    "📉 BOS Bearish | {{ticker}}")
alertcondition(bullFVG,   "ISC · FVG Bullish", "📐 Bullish FVG formed | {{ticker}}")
alertcondition(bearFVG,   "ISC · FVG Bearish", "📐 Bearish FVG formed | {{ticker}}")

// ================================================================
// ░░  DASHBOARD
// ================================================================

wr    = tot > 0 ? won / tot * 100 : 0.0
net   = rw - rl
wrc   = wr >= 55 ? #2ED573 : wr >= 40 ? #FFD700 : #FF4757
netc  = net >= 0 ? #2ED573 : #FF4757

sess  = in_asia ? "🌏  Asia" : in_lon ? "🏦  London" : in_ny ? "🗽  New York" : "💤  Closed"
sessc = in_asia ? #7B7BFF   : in_lon ? #FFD700       : in_ny ? #00D4AA       : color.gray
qt    = in_asia ? "Q1 · Accumulation" : in_lon ? "Q2 · Manipulation" : in_ny ? "Q3 · Distribution" : "Q4 · Reversal"
kzt   = in_kz   ? "✅  ACTIVE" : "—  Waiting"
kzc   = in_kz   ? #2ED573 : color.gray

stt   = t_on ? (t_buy ? "▲  BUY LIMIT" : "▼  SELL LIMIT") : "—  No Signal"
stc   = t_on ? (t_buy ? #00D4AA : #FF6B6B) : color.gray

var table tb = table.new(position.top_right, 2, 17,
     bgcolor=color.new(#07071a, 6),
     border_color=color.new(#1a1a3a, 0),
     border_width=0,
     frame_color=color.new(#2a2a5a, 55),
     frame_width=1)

r(row, lbl, val, vc) =>
    table.cell(tb, 0, row, lbl, text_color=color.new(color.white, 50), text_size=size.tiny, bgcolor=color.new(#07071a, 0))
    table.cell(tb, 1, row, val, text_color=vc, text_size=size.tiny, bgcolor=color.new(#07071a, 0))

// Header
table.cell(tb, 0, 0, "ISC Pro", text_color=#A29BFE, text_size=size.small, bgcolor=color.new(#0d0d2a, 0))
table.cell(tb, 1, 0, "Analyzer ✦", text_color=#FFD700, text_size=size.small, bgcolor=color.new(#0d0d2a, 0))

// Market
table.cell(tb, 0, 1, "── Market", text_color=color.new(#A29BFE, 45), text_size=size.tiny, bgcolor=color.new(#07071a, 0))
table.cell(tb, 1, 1, "", text_color=color.white, text_size=size.tiny, bgcolor=color.new(#07071a, 0))

r(2,  "Session",   sess, sessc)
r(3,  "QT Phase",  qt,   color.new(color.white, 20))
r(4,  "Kill Zone", kzt,  kzc)
r(5,  "Asia H",    na(ah) ? "—" : str.tostring(ah, format.mintick), #FFD700)
r(6,  "Asia L",    na(al) ? "—" : str.tostring(al, format.mintick), #7B7BFF)

// Trade
table.cell(tb, 0, 7, "── Signal", text_color=color.new(#A29BFE, 45), text_size=size.tiny, bgcolor=color.new(#07071a, 0))
table.cell(tb, 1, 7, "", text_color=color.white, text_size=size.tiny, bgcolor=color.new(#07071a, 0))

r(8,  "Status", stt, stc)
r(9,  "Entry",  t_on and not na(t_ep) ? str.tostring(t_ep, format.mintick) : "—", #FFD700)
r(10, "SL",     t_on and not na(t_sl) ? str.tostring(t_sl, format.mintick) : "—", c_sl)
r(11, "TP",     t_on and not na(t_tp) ? str.tostring(t_tp, format.mintick) + " (" + str.tostring(rr_val,"#.#") + "R)" : "—", c_tp)

// Stats
table.cell(tb, 0, 12, "── Stats", text_color=color.new(#A29BFE, 45), text_size=size.tiny, bgcolor=color.new(#07071a, 0))
table.cell(tb, 1, 12, "", text_color=color.white, text_size=size.tiny, bgcolor=color.new(#07071a, 0))

r(13, "Trades",   str.tostring(tot) + " total", color.white)
r(14, "Win Rate",
     str.tostring(math.round(wr, 1)) + "%  (" + str.tostring(won) + "W  " + str.tostring(lst) + "L)",
     wrc)
r(15, "Avg Win",  "+" + str.tostring(math.round(won > 0 ? rw / won : 0, 1)) + "R", #2ED573)
r(16, "Net P/L",  (net >= 0 ? "+" : "") + str.tostring(math.round(net, 1)) + "R", netc)
